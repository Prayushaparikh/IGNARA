# Ignara / DreamPath CodeX — API environment (copy to .env, never commit .env)
# ---------------------------------------------------------------------------

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dreampath
DB_USER=postgres
DB_PASSWORD=postgres

# Server
PORT=4000
NODE_ENV=development

# Auth — REQUIRED in production: long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# CORS — comma-separated frontend origins (protocol + host, no trailing slash)
# Local Vite:
CLIENT_URL=http://localhost:3000
# Production (apex + www):
# CLIENT_URL=https://ignaracodex.com,https://www.ignaracodex.com

# Optional: AI roadmap (Claude)
# ANTHROPIC_API_KEY=

# Optional: Redis (if used elsewhere)
# REDIS_URL=redis://localhost:6379
